# Bet21 — SEGREDOS (e SÓ segredos) ficam aqui.
# Copie este arquivo para ".env" e preencha. O .env nunca é versionado.
# Todo o resto (modelo, janelas, banca, captura...) se configura na aba Configuração do app.

# Chave da API-Football (api-sports.io / v3). Obrigatória pra coletar dados.
APIFOOTBALL_KEY=

# Telegram (OPCIONAL — o app funciona 100% sem isto; os sinais aparecem no dashboard).
# Configure depois, quando quiser receber sinais no celular.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Porta do dashboard local (opcional; padrão 21321).
PORT=
